# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption
TOKEN_ENCRYPTION_SECRET=your-32-char-random-secret

# Meta / Facebook
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
NEXT_PUBLIC_META_APP_ID=your-meta-app-id
META_REDIRECT_URI=http://localhost:3000/api/oauth/facebook/callback

# YouTube / Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/oauth/youtube/callback

# AI APIs (configured per workspace by users)
# Users enter these in workspace settings, stored encrypted in DB

# Queue (Inngest)
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Cron security
CRON_SECRET=your-random-cron-secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
